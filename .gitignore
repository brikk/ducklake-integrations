/.idea/

# Gradle build outputs + caches (the build now lives at the repo root).
.gradle
build/
.kotlin/
!gradle/wrapper/gradle-wrapper.jar

# IDE / tooling
*.iml
*.ipr
*.iws
out/
.vscode/
.settings/
.project
.classpath
.qodana/

# Qodana spills its container HOME (JDK downloads, prefs) into the repo root via the
# bind mount when `qodana scan` runs from jvm/. Ignore the leakage.
/.java/
/.jdks/
/.local/

# Vendored upstream repos for research/audit. The directories themselves
# are never committed; only the clone script and any of our own docs at
# the top level of vendor/ are tracked.
/vendor/*/

# Claude Code local state. The shared workflow scripts under .claude/workflows/
# stay tracked; everything else (local settings.local.json, worktrees, agent
# state) is per-developer and ignored.
/.claude/*
!/.claude/workflows/
