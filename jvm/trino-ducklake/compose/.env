PLUGIN_VERSION=480-1-ALPHA
TRINO_VERSION=480
POSTGRES_VERSION=18-alpine
MINIO_TAG=RELEASE.2025-01-20T14-49-07Z
MC_TAG=RELEASE.2025-01-17T23-25-50Z
DUCKDB_VERSION=1.5.2

POSTGRES_DB=ducklake
POSTGRES_USER=ducklake
POSTGRES_PASSWORD=ducklake

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=ducklake

# TPC-H seed: scale factor for DuckDB's tpch.dbgen.
#   0     -> skip seeding entirely
#   0.01  -> ~6 MB, fast dev default
#   0.1   -> ~60 MB
#   1     -> ~1 GB
TPCH_SCALE_FACTOR=0.01
TPCH_SCHEMA=tpch
